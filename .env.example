VIANEXUS_API_TOKEN=your_vianexus_api_token

# Laptop worker primary database. This stores raw VNX, raw delayed, and matched rows.
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/vnx_quote_accuracy

# Optional cloud dashboard replica. This receives matched rows only.
# MATCHED_REPLICA_DATABASE_URL=postgresql://neon_user:neon_password@neon_host/neondb?sslmode=require

# Split PostgreSQL fields are kept for local fallback if DATABASE_URL is removed.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vnx_quote_accuracy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

BATCH_SIZE=100
COLLECTION_INTERVAL_SECONDS=60
MATCHER_INTERVAL_SECONDS=300
MATCHER_VALID_WINDOW_SECONDS=60
MATCHER_LOOKBACK_HOURS=24
MATCHER_DELAYED_PADDING_SECONDS=900
SAVE_CSV_BACKUP=false
HEALTH_HEARTBEAT_INTERVAL_SECONDS=300
RAW_RETENTION_DAYS=0
MATCHED_RETENTION_DAYS=0
RETENTION_INTERVAL_SECONDS=3600

DASHBOARD_AUTH_ENABLED=false
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me
